# CPEG - Contract Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Deployer wallet private key (WITHOUT 0x prefix)
PRIVATE_KEY=your_private_key_here

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Base Mainnet RPC
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Basescan API key for contract verification
# Get one at: https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here

# Deployed contract addresses (filled in after deployment)
CPEG_TOKEN_ADDRESS=
CPEG_ADDRESS=

# Keeper address to authorize (for setKeeper script)
# For Chainlink Automation: use the forwarder address from the upkeep dashboard
KEEPER_ADDRESS=
KEEPER_STATUS=true

# NFT metadata URI ({id} is replaced by token ID 1-6)
NFT_BASE_URI=https://cpeg.io/api/token/{id}.json

# Optional: enable gas reporting in tests
REPORT_GAS=false
